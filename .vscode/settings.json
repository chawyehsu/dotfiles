{
  "shellcheck.enable": true,
  "editor.formatOnSave": false,
  "powershell.codeFormatting.useCorrectCasing": true,
  "files.associations": {
    ".condarc": "yaml",
    ".wslconfig": "ini",
    "*.nanorc": "ini",
    "**/.config/bat/config": "ini",
    "**/.config/ghostty/config": "ini",
    "**/.config/ghostty/themes/*": "ini",
    "**/.config/htop/htoprc": "ini",
    "**/.config/mintty/config": "ini",
    "**/.config/npm/npmrc": "ini",
    "**/.config/pnpm/rc": "ini",
    "**/.config/readline/inputrc": "properties",
    "**/.config/screen/screenrc": "ini",
    "**/.config/wget/wgetrc": "ini",
    "nanorc": "shellcheckrc"
  }
}
